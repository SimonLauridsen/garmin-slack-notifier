# Garmin Connect credentials (same account used in garmin_login.py)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Comma-separated list of Garmin display names to watch.
# Find a display name in the profile URL: connect.garmin.com/profile/<DisplayName>
# Your own display name is shown in garmin_login.py output.
GARMIN_WATCH_USERS=friend-display-name,another-friend-display-name,your-own-display-name

# Slack bot token (xoxb-...) — needs chat:write permission
SLACK_BOT_TOKEN=xoxb-your-token-here

# Channel to post to (name with # or channel ID)
SLACK_CHANNEL=#running
